PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/securelend?retryWrites=true&w=majority
# Optional: use a standard mongodb:// URI if your network blocks SRV DNS lookups.
MONGODB_URI_FALLBACK=
# Optional: DNS resolvers used to derive non-SRV Atlas hosts when SRV lookup fails locally.
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace_me
JWT_EXPIRES_IN=7d
ML_SERVICE_URL=https://your-ml-service.onrender.com
CORS_ORIGINS=https://your-frontend.vercel.app

# Blockchain (Hedera)
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.<account-id>
HEDERA_PRIVATE_KEY=<hedera-private-key>
HEDERA_CONTRACT_ID=0.0.<contract-id>

# Admin seed configuration
ADMIN_NAME=<admin-name>
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<strong-admin-password>
ADMIN_PHONE=<admin-phone>
